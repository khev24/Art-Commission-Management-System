package FinalsProject;

import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import java.awt.*;

public class ViewPortfolioPanel extends JPanel {

    private SystemManager system = SystemManager.getInstance();

    private DefaultTableModel portfolioModel;
    private JTable portfolioTable;

    public ViewPortfolioPanel() {

        setLayout(null);

        initUI();
        loadPortfolio();
    }

    private void initUI() {

        JLabel title = new JLabel("View Portfolio");
        title.setFont(new Font("Tahoma", Font.BOLD, 16));
        title.setBounds(20, 10, 200, 25);
        add(title);

        portfolioModel = new DefaultTableModel(
                new String[]{"Title", "Category", "Artist"}, 0
        );

        portfolioTable = new JTable(portfolioModel);

        JScrollPane scrollPane = new JScrollPane(portfolioTable);
        scrollPane.setBounds(10, 50, 800, 350);
        add(scrollPane);
    }

    public void loadPortfolio() {

        portfolioModel.setRowCount(0);

        for (Artwork art : system.getAllArtworks()) {
            portfolioModel.addRow(new Object[]{
                    art.getTitle(),
                    art.getCategory(),
                    art.getArtistUsername()
            });
        }
    }
}
